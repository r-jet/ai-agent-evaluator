# ── Secrets — NEVER commit these ──────────────────────────────────────────
.env
*.env
env.properties
config/secrets.*

# ── Build output ───────────────────────────────────────────────────────────
target/
*.class
*.jar
*.war

# ── Reports (generated at runtime — too large/noisy for Git) ──────────────
reports/

# ── Excel scenario files (may contain internal info) ──────────────────────
