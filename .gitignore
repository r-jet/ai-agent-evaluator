*.xlsx

# ── IntelliJ IDEA ─────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── macOS ──────────────────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
requests.log
conversation_log.txt